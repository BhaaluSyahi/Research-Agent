# Supabase
SUPABASE_KEY=your-service-role-key  # never the anon key

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# SQS Queues
SQS_REQUESTS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/requests.fifo
SNS_TOPIC_ROUTER_ARN=arn:aws:sns:ap-south-1:123456789:topic_router

# Enrichment queues (one per topic)
SQS_ENRICH_FLOODS_URL=https://sqs.ap-south-1.amazonaws.com/123456789/enrich.floods.fifo
SQS_ENRICH_DROUGHT_URL=https://sqs.ap-south-1.amazonaws.com/123456789/enrich.drought.fifo
SQS_ENRICH_HEALTHCARE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/enrich.healthcare.fifo
SQS_ENRICH_DISASTER_URL=https://sqs.ap-south-1.amazonaws.com/123456789/enrich.disaster.fifo
SQS_ENRICH_WELFARE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/enrich.welfare.fifo
SQS_ENRICH_EDUCATION_URL=https://sqs.ap-south-1.amazonaws.com/123456789/enrich.education.fifo
SQS_ENRICH_LIVELIHOOD_URL=https://sqs.ap-south-1.amazonaws.com/123456789/enrich.livelihood.fifo
SQS_ENRICH_ENVIRONMENT_URL=https://sqs.ap-south-1.amazonaws.com/123456789/enrich.environment.fifo
SQS_ENRICH_REGIONAL_URL=https://sqs.ap-south-1.amazonaws.com/123456789/enrich.regional.fifo

# Gemini
GEMINI_API_KEY=AIzaSy...   # Google AI Studio key — get one free at aistudio.google.com
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-2.0-flash

# Tavily
TAVILY_API_KEY=tvly-...

# Matching Thresholds (optional - defaults shown) 
RAG_SUFFICIENCY_MIN_RESULTS=3
RAG_SUFFICIENCY_MIN_SCORE=0.75
RAG_TOP_K=20
RAG_RERANK_TOP_N=5

# Crawler (optional - defaults shown) 
CRAWLER_DEFAULT_FREQUENCY_HOURS=6
CRAWLER_MAX_ARTICLES_PER_RUN=20
